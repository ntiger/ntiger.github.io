---
import '../styles/global.css';
const { title = 'Xiao Wang', description = 'Engineering Manager, Full-Stack & Quantitative Development' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="container">
      <header class="glass masthead">
        <div class="brand">
          <img src="/images/xwang.jpg" alt="Xiao Wang avatar" class="avatar" />
          <div>
            <h1>Xiao Wang</h1>
            <p>Engineering Manager, Full-Stack & Quantitative Development</p>
          </div>
        </div>
        <nav>
          <a href="/">Home</a>
          <a href="/cv">CV</a>
          <a href="/about">About</a>
        </nav>
      </header>

      <main class="glass content">
        <slot />
      </main>

      <footer class="glass footer">
        <a href="https://github.com/ntiger" target="_blank">GitHub</a>
        <a href="https://twitter.com/nwtiger" target="_blank">Twitter</a>
        <a href="mailto:shawn.ntiger@gmail.com">Email</a>
      </footer>
    </div>
  </body>
</html>
